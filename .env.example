# 복사해서 .env 로 사용 (.env는 git에 커밋하지 않는다)

# 운영 PostgreSQL 전환 시 (미설정이면 PGlite ./data/pg 사용)
# DATABASE_URL=postgres://user:pw@host:5432/planner

# ---- Phase 4: Google Calendar 단방향 연동 (서비스 계정 방식) ----
