# 복사해서 .env 로 사용 (.env는 git에 커밋하지 않는다)

# ── 로컬 개발 DB ──
# 미설정이면 PGlite(./data/pg) 사용 = 기본(오프라인 가능, 계정 불필요).
# Neon에 붙여 테스트하거나 배포용으로 쓸 때만 설정한다.
# DATABASE_URL=postgresql://user:pw@host-pooler.../neondb?sslmode=require

# ── Neon PostgreSQL (Phase 5 배포) ──
# 런타임(서버리스)은 풀드(-pooler), 스키마 생성(npm run db:setup)은 언풀드(직접) 권장.
# 프로덕션은 Vercel 환경변수에 DATABASE_URL(풀드)로 등록한다.
NEON_DATABASE_URL=postgresql://user:pw@host-pooler.../neondb?sslmode=require
NEON_DATABASE_URL_UNPOOLED=postgresql://user:pw@host.../neondb?sslmode=require

# ── Vercel Blob (Phase 5, 메모 이미지) ──
# Vercel Storage에서 Blob 생성 시 스토어 이름 프리픽스가 붙은 PLAN_BLOB_* 로 발급됨.
# 코드는 BLOB_READ_WRITE_TOKEN → PLAN_BLOB_READ_WRITE_TOKEN 순으로 읽는다.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx
PLAN_BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx
PLAN_BLOB_STORE_ID=store_xxx

# ── Cron (Phase 5, 캘린더 재시도 엔드포인트 보호) ──
CRON_SECRET=<랜덤 문자열>

# ── Google Calendar 단방향 연동 (서비스 계정) ──
# 서비스 계정 키 JSON을 base64 인코딩한 값 (원본 JSON 문자열도 허용).
# 대상 캘린더는 이 서비스 계정 이메일(client_email)에 '일정 변경' 권한으로 공유되어 있어야 한다.
GOOGLE_SERVICE_ACCOUNT_JSON="<base64 encoded service account json>"

# 연동 대상 캘린더 (chchun88@gmail.com 소유)
GCAL_FAMILY_LABEL=가족일정
GCAL_FAMILY_ID=98e2q06atf3dj191l6082akbd8@group.calendar.google.com
GCAL_STUDENT_LABEL=시윤학원
