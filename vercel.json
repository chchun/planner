{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "crons": [
    { "path": "/api/cron/retry-gcal", "schedule": "0 18 * * *" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
